# ═══════════════════════════════════════════════════════════
#  GTB BANK — Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs réelles.
#  NE JAMAIS committer le fichier .env dans le repo.
# ═══════════════════════════════════════════════════════════

# Environnement : development | production
GTB_ENV=production

# ── Base de données ──────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=gtb
DB_USER=gtb_user
DB_PASS=CHANGE_ME_strong_password

# ── Sécurité ─────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
APP_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Email — Brevo (ex-Sendinblue) ────────────────────────────
# Obtenir sur : https://app.brevo.com/settings/keys/api
BREVO_API_KEY=CHANGE_ME_your_brevo_api_key
